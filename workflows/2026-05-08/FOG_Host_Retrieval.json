    {
      "parameters": {
        "jsCode": "// Standardize module output format - EXTRACT AND FILTER HOSTS FROM HTTP RESPONSE\nconst hosts = [];\nconst validHosts = [];\nconst errors = [];\n\n// The HTTP response contains {count: X, hosts: [...]}\n// We need to extract the hosts array from the first item\ntry {\n  const response = items[0].json;\n  \n  if (response && response.hosts && Array.isArray(response.hosts)) {\n    // Extract each host from the hosts array\n    for (const host of response.hosts) {\n      hosts.push(host);\n      \n      // Check if host has valid inventory data\n      if (host.inventory && host.inventory.id) {\n        // Check for valid serial number\n        const serial = host.inventory.sysserial;\n        if (serial && \n            serial !== 'System Serial Number' && \n            serial !== 'To be filled by O.E.M.' &&\n            serial !== 'Default string') {\n          validHosts.push(host);\n        }\n      }\n    }\n  } else {\n    errors.push({\n      json: {\n        error: true,\n        error_code: 'INVALID_RESPONSE_FORMAT',\n        error_message: 'HTTP response does not contain valid hosts array',\n        error_details: {\n          response_structure: response,\n          expected_structure: '{count: number, hosts: [...]}'\n        },\n        module_metadata: {\n          module_name: 'FOG_Host_Retrieval',\n          module_version: '1.0.0'\n        },\n        timestamp: new Date().toISOString()\n      }\n    });\n  }\n} catch (error) {\n  errors.push({\n    json: {\n      error: true,\n      error_code: 'HOST_EXTRACTION_ERROR',\n      error_message: `Failed to extract hosts: ${error.message}`,\n      error_details: {\n        error_stack: error.stack\n      },\n      module_metadata: {\n        module_name: 'FOG_Host_Retrieval',\n        module_version: '1.0.0'\n      },\n      timestamp: new Date().toISOString()\n    }\n  });\n}\n\n// Return single standardized output with only valid hosts\nreturn [{\n  json: {\n    success: true,\n    data: {\n      hosts: validHosts,  // Only valid hosts\n      total_hosts: hosts.length,\n      valid_hosts: validHosts.length,\n      invalid_hosts: hosts.length - validHosts.length,\n      retrieved_at: new Date().toISOString()\n    },\n    metadata: {\n      module_name: 'FOG_Host_Retrieval',\n      module_version: '1.0.0',\n      execution_id: $executionId,\n      items_processed: hosts.length,\n      source: 'fog_api'\n    }\n  }\n}, ...errors];"
      },
