    {
      "parameters": {
        "jsCode": "// Prepare FOG deletion requests for each host\nconst results = items.map(item => {\n  const input = item.json;\n  \n  console.log(`Preparing FOG deletion for: ${input.computer_name} (FOG Host ID: ${input.fog_host_id})`);\n  \n  return {\n    json: {\n      // Data for FOG API\n      fog_host_id: input.fog_host_id,\n      \n      // Metadata for tracking\n      postgres_id: input.postgres_id,\n      computer_name: input.computer_name,\n      inventory_number: input.inventory_number,\n      glpi_computer_id: input.glpi_computer_id,\n      serial_number: input.serial_number\n    }\n  };\n});\n\nconsole.log(`Prepared ${results.length} FOG deletion requests`);\nreturn results;"
      },
