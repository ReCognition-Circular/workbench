    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE created_computers \nSET \n    status = CASE \n        WHEN $1 = true THEN 'deleted_from_fog' \n        ELSE 'fog_deletion_failed' \n    END,\n    fog_deleted_at = CASE \n        WHEN $1 = true THEN NOW() \n        ELSE NULL \n    END,\n    fog_deletion_error = $2\nWHERE id = $3",
        "options": {
          "queryReplacement": "={{$json.deletion_success}}, {{$json.deletion_error}}, {{$json.postgres_id}}"
        }
      },
