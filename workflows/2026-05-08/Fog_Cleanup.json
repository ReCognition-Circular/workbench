    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    id as postgres_id,\n    fog_host_id,\n    computer_name,\n    inventory_number,\n    glpi_computer_id,\n    serial_number\nFROM created_computers \nWHERE status = 'created' \n  AND fog_host_id IS NOT NULL\n  AND glpi_computer_id IS NOT NULL\nORDER BY id;",
        "options": {}
      },
