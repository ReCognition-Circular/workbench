    {
      "parameters": {
        "jsCode": "// Process FOG deletion results\nconst results = items.map(item => {\n  const input = item.json;\n  const response = item.response;\n  \n  // Check if deletion was successful\n  const success = response && response.status === 200;\n  const error = response && response.error ? response.error : null;\n  \n  console.log(`FOG deletion for ${input.computer_name}: ${success ? 'SUCCESS' : 'FAILED'}`);\n  \n  return {\n    json: {\n      // Original data\n      ...input,\n      \n      // Deletion results\n      deletion_success: success,\n      deletion_error: error,\n      deletion_response: response,\n      \n      // Timestamp\n      deleted_at: success ? new Date().toISOString() : null\n    }\n  };\n});\n\n// Log summary\nconst successCount = results.filter(r => r.json.deletion_success).length;\nconst failCount = results.length - successCount;\nconsole.log(`FOG deletion summary: ${successCount} successful, ${failCount} failed`);\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
        -160
      ],
      "id": "ca8c4f88-2e0a-4c4e-9591-e1ae05743fcb",
